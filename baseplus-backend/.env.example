# Profile: dev, docker or prod. Dev does not require an .env file.
SPRING_PROFILES_ACTIVE=docker

# Optional in dev. Required in docker and prod.
# Replace with a long, random value and never commit the real secret.
JWT_SECRET=replace-with-a-long-random-secret

# Physical directory used to store uploaded files.
# Use an absolute persistent path in production, for example /opt/baseplus/uploads.
UPLOAD_DIR=uploads

# Comma-separated list of frontend origins allowed by backend CORS.
# Keep exact origins only. Do not use "*".
BASEPLUS_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional local tunnel example. Keep real tunnel domains only in your local .env.
# BASEPLUS_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-tunnel.ngrok-free.app
# VITE_ALLOWED_HOSTS=your-tunnel.ngrok-free.app

# Docker profile and Docker Compose defaults.
# These variables are optional for local Docker execution.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baseplus
DB_USER=baseplus
DB_PASSWORD=replace-with-a-local-password

# Manual administrative bootstrap.
# Use only for the first administrator in docker/prod, then remove from the environment.
BASEPLUS_BOOTSTRAP_ADMIN_ENABLED=false
BASEPLUS_BOOTSTRAP_ADMIN_NAME=
BASEPLUS_BOOTSTRAP_ADMIN_EMAIL=
BASEPLUS_BOOTSTRAP_ADMIN_PASSWORD=

# Production profile.
# DB_URL, DB_USER and DB_PASSWORD are required when the prod profile is active.
DB_URL=jdbc:postgresql://database-host:5432/baseplus

# Reserved for future external integrations. These values are not consumed yet.
EXTERNAL_API_ENABLED=false
EXTERNAL_API_KEY=
EXTERNAL_API_RATE_LIMIT=60
